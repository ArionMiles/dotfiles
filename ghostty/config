font-family = JetBrainsMono Nerd Font
font-size = 14
theme = TokyoNight
window-save-state = always
clipboard-read = "allow"
clipboard-paste-protection = false
clipboard-trim-trailing-spaces = true
mouse-hide-while-typing = true
cursor-style-blink = true
cursor-style = block
quit-after-last-window-closed = true
confirm-close-surface = false

# Notify when a long running command finishes
notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 2m

# Custom notification sound for the bell
bell-features = audio
bell-audio-path = /System/Library/Sounds/Blow.aiff

# GTK specific config
gtk-titlebar = false

# MacOS specific config
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
macos-icon = xray
macos-option-as-alt = true

# Shady stuff
#custom-shader = ~/.config/ghostty/shaders/retro-terminal.glsl
#custom-shader = ~/.config/ghostty/shaders/bloom.glsl

# Play nice with SSH and other things
shell-integration-features = ssh-terminfo,ssh-env,no-cursor

#
# Keybinds
#
keybind = global:alt+shift+q=toggle_quick_terminal

# Navigate between panes (vim-style)
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

# Use tmux shortcuts for creating/switching tabs
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>\=new_split:right
keybind = ctrl+a>-=new_split:down
keybind = ctrl+a>z=toggle_split_zoom
